# Copy to .env and fill in real values before starting the server.

# Port to bind on. Default 3000.
PORT=3000

# Bind address. Use 0.0.0.0 to accept connections from other devices on the network,
# or 127.0.0.1 if running behind a reverse proxy like nginx on the same host.
HOST=0.0.0.0

# Secret used to sign JWT session cookies. MUST be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Set to "true" when serving over HTTPS — the auth cookie will be marked Secure.
COOKIE_SECURE=false

# Path to the SQLite database file. Created automatically on first run.
DB_PATH=./data/calendar.db

# Session lifetime in days.
SESSION_DAYS=30
